# Required for live LLM extraction/chat.
# Choose the provider during implementation. Do not commit real keys.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=120

# Optional live web search provider for source discovery.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Local storage.
COMPANY_RAG_DB_PATH=data/company_rag.sqlite
COMPANY_RAG_CACHE_DIR=data/cache
